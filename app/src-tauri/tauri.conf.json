{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-vs-electron/refs/heads/main/tauri.conf-v2-schema.json",
  "productName": "Hestia",
  "version": "0.1.1",
  "identifier": "com.web4.hestia",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hestia",
        "width": 1200,
        "height": 800,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
